{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "dev:staging": "NODE_ENV=development tsx --env-file=.env.staging server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:staging": "vite build --mode staging && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auth": "node test-auth.js",
    "create:user": "node create-user.js",
    "create-firebase-test-users": "tsx scripts/create-firebase-test-users.ts",
    "verify:db": "tsx scripts/verify-db.ts",
    "db:schema": "tsx scripts/run-schema.ts",
    "load-test": "tsx scripts/load-test.ts",
    "test:root-api": "tsx scripts/test-root-api.ts",
    "export-firestore": "cd functions && npm run export-firestore"
  },
